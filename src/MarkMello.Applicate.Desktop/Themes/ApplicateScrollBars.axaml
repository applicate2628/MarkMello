<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Single source of truth for every Avalonia ScrollBar in the app.
       ScrollBarSize drives the track, hit target, and Thumb cross-axis size.
       Always visible, faint track, gray theme thumb, arrows kept. -->

  <Styles.Resources>
    <sys:Double x:Key="ScrollBarSize">14</sys:Double>
  </Styles.Resources>

  <Style Selector="ScrollBar">
    <Setter Property="AllowAutoHide" Value="False" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ScrollBar:vertical">
    <Setter Property="Width" Value="{DynamicResource ScrollBarSize}" />
    <Setter Property="MinWidth" Value="{DynamicResource ScrollBarSize}" />
  </Style>
  <Style Selector="ScrollBar:horizontal">
    <Setter Property="Height" Value="{DynamicResource ScrollBarSize}" />
    <Setter Property="MinHeight" Value="{DynamicResource ScrollBarSize}" />
  </Style>

  <!-- Track: faint visible strip behind the thumb (Chrome paints one). -->
  <Style Selector="ScrollBar /template/ Track">
    <Setter Property="UseLayoutRounding" Value="False" />
  </Style>
  <Style Selector="ScrollBar /template/ Border#TrackRect">
    <Setter Property="Background" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <!-- Thumb shared state. Per-orientation templates below bind the painted
       short-axis dimension to ScrollBarSize too, so Fluent's actual Thumb
       bounds and the visible pill cannot drift apart. -->
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="UseLayoutRounding" Value="False" />
  </Style>
  <Style Selector="ScrollBar:vertical /template/ Thumb">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="60" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                Width="{DynamicResource ScrollBarSize}"
                HorizontalAlignment="Center"
                CornerRadius="7" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar:horizontal /template/ Thumb">
    <Setter Property="MinWidth" Value="60" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                Height="{DynamicResource ScrollBarSize}"
                VerticalAlignment="Center"
                CornerRadius="7" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ScrollBar /template/ Thumb:pressed">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
  </Style>

</Styles>
