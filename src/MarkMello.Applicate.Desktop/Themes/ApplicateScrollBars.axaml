<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime">

  <!-- Single source of truth for every Avalonia ScrollBar in the app.
       ScrollBarSize drives the track width and hit target; ScrollBarThumbSize
       is the narrower visible pill, centered so the faint track shows on both
       sides of the thumb. Always visible, faint track, gray theme thumb,
       arrows kept. -->

  <Styles.Resources>
    <sys:Double x:Key="ScrollBarSize">12</sys:Double>
    <sys:Double x:Key="ScrollBarThumbSize">8</sys:Double>
  </Styles.Resources>

  <Style Selector="ScrollBar">
    <Setter Property="AllowAutoHide" Value="False" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ScrollBar:vertical">
    <Setter Property="Width" Value="{DynamicResource ScrollBarSize}" />
    <Setter Property="MinWidth" Value="{DynamicResource ScrollBarSize}" />
  </Style>
  <Style Selector="ScrollBar:horizontal">
    <Setter Property="Height" Value="{DynamicResource ScrollBarSize}" />
    <Setter Property="MinHeight" Value="{DynamicResource ScrollBarSize}" />
  </Style>

  <!-- Track: faint visible strip behind the thumb (Chrome paints one). -->
  <Style Selector="ScrollBar /template/ Track">
    <Setter Property="UseLayoutRounding" Value="False" />
  </Style>
  <Style Selector="ScrollBar /template/ Border#TrackRect">
    <Setter Property="Background" Value="{DynamicResource MmBorderBrush}" />
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <!-- Thumb shared state. The Thumb keeps the full ScrollBarSize hit target
       (easy to grab); the per-orientation templates paint a narrower
       ScrollBarThumbSize pill, centered, so the faint track stays visible on
       both sides of the thumb. -->
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="Background" Value="{DynamicResource MmTextSoftBrush}" />
    <Setter Property="UseLayoutRounding" Value="False" />
  </Style>
  <Style Selector="ScrollBar:vertical /template/ Thumb">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="60" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                Width="{DynamicResource ScrollBarThumbSize}"
                HorizontalAlignment="Center"
                CornerRadius="4" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar:horizontal /template/ Thumb">
    <Setter Property="MinWidth" Value="60" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                Height="{DynamicResource ScrollBarThumbSize}"
                VerticalAlignment="Center"
                CornerRadius="4" />
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ScrollBar /template/ Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
  </Style>
  <Style Selector="ScrollBar /template/ Thumb:pressed">
    <Setter Property="Background" Value="{DynamicResource MmTextBrush}" />
  </Style>

</Styles>
