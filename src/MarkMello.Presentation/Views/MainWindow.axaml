<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MarkMello.Presentation.ViewModels"
        xmlns:views="using:MarkMello.Presentation.Views"
        mc:Ignorable="d"
        x:Class="MarkMello.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="840"
        WindowStartupLocation="CenterScreen"
        MinWidth="640" MinHeight="480"
        Title="{Binding WindowTitle}"
        Topmost="{Binding IsAlwaysOnTop}"
        Icon="/Assets/Icons/markmello.ico"
        Background="{DynamicResource MmBackgroundBrush}"
        DragDrop.AllowDrop="True"
        UseLayoutRounding="True">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:EditorSessionViewModel"
                  x:DataType="vm:EditorSessionViewModel">
      <views:EditWorkspaceView />
    </DataTemplate>
  </Window.DataTemplates>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding CreateNewDocumentCommand}" />
    <KeyBinding Gesture="Cmd+N" Command="{Binding CreateNewDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Cmd+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ToggleEditModeCommand}" />
    <KeyBinding Gesture="Cmd+E" Command="{Binding ToggleEditModeCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
    <KeyBinding Gesture="Cmd+S" Command="{Binding SaveCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="Cmd+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="F5" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Cmd+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding ClearErrorCommand}" />
    <KeyBinding Gesture="Ctrl+T" Command="{Binding ToggleTocCommand}" />
    <KeyBinding Gesture="Cmd+T" Command="{Binding ToggleTocCommand}" />
  </Window.KeyBindings>

  <Window.Styles>
    <Style Selector="Border.mm-top-chrome">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform" Value="translate(0px,-4px)" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window.mm-top-chrome-hover Border.mm-top-chrome">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>
    <Style Selector="Window.mm-overlay-open Border.mm-top-chrome">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>

    <Style Selector="StackPanel.mm-titlebar-actions">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="RenderTransform" Value="translate(0px,-2px)" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window.mm-top-chrome-hover StackPanel.mm-titlebar-actions">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>
    <Style Selector="Window.mm-overlay-open StackPanel.mm-titlebar-actions">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform" Value="translate(0px,0px)" />
    </Style>

    <Style Selector="Border.mm-status">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.20" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-status">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Border.mm-update-notification">
      <Setter Property="Background" Value="{DynamicResource MmSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MmAccentSoftBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="BoxShadow" Value="0 14 32 0 #26000000" />
    </Style>

    <Style Selector="Border.mm-progress">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Width" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.12" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-progress">
      <Setter Property="Opacity" Value="0.6" />
    </Style>
  </Window.Styles>

  <Border Name="ShellRoot"
          Background="{DynamicResource MmBackgroundBrush}"
          BorderBrush="{DynamicResource MmBorderBrush}"
          BorderThickness="1">
    <Border.Transitions>
      <Transitions>
        <DoubleTransition Property="Opacity"
                          Duration="{DynamicResource MmDurationStandard}"
                          Easing="{DynamicResource MmEasingStandard}" />
      </Transitions>
    </Border.Transitions>

    <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Height="36"
            Background="{DynamicResource MmTitleBarBrush}"
            PointerEntered="OnTopChromePointerEntered"
            PointerExited="OnTopChromePointerExited">
      <DockPanel LastChildFill="True"
                 ClipToBounds="True">
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    IsVisible="{Binding ShowCustomTitleBar}">
          <Button Classes="titlebar"
                  Click="OnMinimizeClick"
                  ToolTip.Tip="{Binding TitleBarMinimize}">
            <Path Data="M0,5 L10,5"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
          <!-- Glyph + tooltip are owned by code-behind (MainWindow.axaml.cs):
               they flip between Maximize and Restore by WindowState, which the
               VM cannot observe. See UpdateMaximizeRestoreAffordance. -->
          <Button Name="MaximizeRestoreButton"
                  Classes="titlebar"
                  Click="OnMaximizeClick">
            <Path Name="MaximizeRestoreGlyph"
                  Data="M0,0 L10,0 L10,10 L0,10 Z"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1"
                  Fill="Transparent" />
          </Button>
          <Button Classes="titlebar close"
                  Click="OnCloseClick"
                  ToolTip.Tip="{Binding TitleBarClose}">
            <Path Data="M0,0 L10,10 M10,0 L0,10"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Classes="mm-titlebar-actions"
                    Orientation="Horizontal"
                    Spacing="6"
                    MinWidth="206"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
          <Grid Width="58"
                Height="28"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <Button Classes="topbar-ghost"
                      IsVisible="{Binding ShowsDirtySaveButton}"
                      Command="{Binding SaveCommand}"
                      ToolTip.Tip="{Binding SaveTooltip}">
                <Grid Width="14"
                      Height="14">
                  <Path Data="M2.25 1.75H10.5L11.75 3V12.25H2.25Z M4 1.75V5.25H9.5V1.75 M4 12.25V8H10V12.25"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="1.35"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent"
                        Stretch="Uniform" />
                </Grid>
              </Button>

              <Button Classes="topbar-ghost"
                      IsVisible="{Binding IsEditMode}"
                      Command="{Binding SaveAsCommand}"
                      ToolTip.Tip="{Binding SaveAsTooltip}">
                <Grid Width="14"
                      Height="14">
                  <Path Data="M2.25 1.75H10.5L11.75 3V12.25H2.25Z M4 1.75V5.25H9.5V1.75 M4 12.25V8H9"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="1.25"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent"
                        Stretch="Uniform" />
                  <Path Data="M8.25 10.75L11.5 7.5 12.5 8.5 9.25 11.75 8 12Z"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="1.05"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent"
                        Stretch="Uniform" />
                </Grid>
              </Button>
            </StackPanel>
          </Grid>

          <Button Classes="topbar-ghost"
                  Command="{Binding CycleThemeCommand}"
                  ToolTip.Tip="{Binding NextThemeHint}">
            <Grid Width="14" Height="14">
              <Path IsVisible="{Binding ShowsMoonThemeIcon}"
                    Data="M10.5 8.5A4 4 0 1 1 5.5 3.5 3.2 3.2 0 0 0 10.5 8.5Z"
                    Stroke="{DynamicResource MmTextSoftBrush}"
                    StrokeThickness="1.5"
                    StrokeJoin="Round"
                    StrokeLineCap="Round"
                    Fill="Transparent"
                    Stretch="Uniform" />
              <Canvas IsVisible="{Binding ShowsSunThemeIcon}"
                      Width="14"
                      Height="14">
                <Ellipse Canvas.Left="4.25"
                         Canvas.Top="4.25"
                         Width="5.5"
                         Height="5.5"
                         Stroke="{DynamicResource MmTextSoftBrush}"
                         StrokeThickness="1.5"
                         Fill="Transparent" />
                <Line StartPoint="7,0.75" EndPoint="7,2.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="7,11.9" EndPoint="7,13.25"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="0.75,7" EndPoint="2.1,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="11.9,7" EndPoint="13.25,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,2.15" EndPoint="3.1,3.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,10.9" EndPoint="11.85,11.85"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,11.85" EndPoint="3.1,10.9"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,3.1" EndPoint="11.85,2.15"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
              </Canvas>
            </Grid>
          </Button>

          <ToggleButton Classes="topbar-action"
                        IsVisible="{Binding ShowsEditToggle}"
                        IsChecked="{Binding IsEditMode, Mode=OneWay}"
                        Command="{Binding ToggleEditModeCommand}"
                        ToolTip.Tip="{Binding EditToggleTooltip}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <Viewbox Width="12"
                       Height="12"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Grid Width="14"
                      Height="14">
                  <Path IsVisible="{Binding ShowsEditPencilIcon}"
                        Data="M2.5 11.5L5 11l6-6-2-2-6 6-.5 2.5zM8.5 3.5l2 2"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="1.5"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                  <Canvas IsVisible="{Binding ShowsReadEyeIcon}"
                          Width="14"
                          Height="14">
                    <Path Data="M1.5 7s2-4 5.5-4 5.5 4 5.5 4-2 4-5.5 4S1.5 7 1.5 7Z"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                    <Ellipse Canvas.Left="5.5"
                             Canvas.Top="5.5"
                             Width="3"
                             Height="3"
                             Stroke="{DynamicResource MmTextSoftBrush}"
                             StrokeThickness="1.5"
                             Fill="Transparent" />
                  </Canvas>
                </Grid>
              </Viewbox>
              <TextBlock Text="{Binding EditToggleLabel}"
                         FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                         FontSize="12" />
            </StackPanel>
          </ToggleButton>

          <ToggleButton Name="SettingsTriggerButton"
                        Classes="topbar-ghost"
                        IsVisible="{Binding IsViewer}"
                        Command="{Binding ToggleSettingsCommand}"
                        IsChecked="{Binding IsSettingsOpen, Mode=OneWay}"
                        ToolTip.Tip="{Binding ReadingSettingsTooltip}">
            <Grid Width="14"
                  Height="14">
              <Viewbox Stretch="Uniform">
                <Canvas Width="24"
                        Height="24">
                  <Path Data="M14,17 L5,17"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent" />
                  <Path Data="M19,7 L10,7"
                        Stroke="{DynamicResource MmTextSoftBrush}"
                        StrokeThickness="2"
                        StrokeLineCap="Round"
                        StrokeJoin="Round"
                        Fill="Transparent" />
                  <Ellipse Canvas.Left="14"
                           Canvas.Top="14"
                           Width="6"
                           Height="6"
                           Stroke="{DynamicResource MmTextSoftBrush}"
                           StrokeThickness="2"
                           Fill="Transparent" />
                  <Ellipse Canvas.Left="4"
                           Canvas.Top="4"
                           Width="6"
                           Height="6"
                           Stroke="{DynamicResource MmTextSoftBrush}"
                           StrokeThickness="2"
                           Fill="Transparent" />
                </Canvas>
              </Viewbox>
            </Grid>
          </ToggleButton>
        </StackPanel>

        <Border MinWidth="0"
                ClipToBounds="True"
                Background="Transparent"
                PointerPressed="OnTitleBarPointerPressed">
          <DockPanel LastChildFill="True"
                     MinWidth="0"
                     ClipToBounds="True"
                     Margin="14,0,0,0"
                     VerticalAlignment="Center">
            <ToggleButton Name="AppMenuTriggerButton"
                          DockPanel.Dock="Left"
                          Classes="topbar-ghost"
                          Margin="0,0,8,0"
                          IsVisible="{Binding ShowsAppMenuControl}"
                          IsChecked="{Binding IsAppOverlayOpen, Mode=OneWay}"
                          Command="{Binding ToggleAppMenuCommand}"
                          ToolTip.Tip="{Binding AppMenuTooltip}">
              <Grid Width="14"
                    Height="14">
                <Path Data="M2.5 4H11.5 M2.5 7H11.5 M2.5 10H11.5"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round"
                      StrokeJoin="Round"
                      Fill="Transparent" />
              </Grid>
            </ToggleButton>
            <Ellipse DockPanel.Dock="Left"
                     Width="5" Height="5"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Fill="{DynamicResource MmAccentBrush}"
                     IsVisible="{Binding HasDocumentTitle}" />
            <TextBlock Text="{Binding WindowTitle}"
                       MinWidth="0"
                       FontSize="12"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource MmTitleBarTextBrush}" />
          </DockPanel>
        </Border>
      </DockPanel>
    </Border>

    <Panel Grid.Row="1"
           Name="BodyPanel">

      <views:WelcomeView ZIndex="0"
                         IsVisible="{Binding IsWelcome}" />
      <ContentControl IsVisible="{Binding IsViewer}"
                      ZIndex="0"
                      Content="{Binding ActiveDocumentContent}" />
      <views:LoadErrorView ZIndex="0"
                           IsVisible="{Binding IsError}" />

      <Border Name="ReadingProgressBar"
              Classes="mm-progress"
              ZIndex="200"
              IsVisible="{Binding IsViewer}"
              Height="1"
              VerticalAlignment="Top"
              HorizontalAlignment="Left"
              Background="{DynamicResource MmAccentBrush}"
              IsHitTestVisible="False" />

      <Border Classes="mm-update-notification"
              ZIndex="320"
              IsVisible="{Binding IsUpdateNotificationVisible}"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Width="360"
              MaxWidth="420"
              Margin="16">
        <Grid ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="12"
              RowSpacing="10">
          <StackPanel Grid.Row="0"
                      Grid.Column="0"
                      Spacing="3">
            <TextBlock Classes="mm-setting-label"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Text="{Binding UpdateStatusTitle}"
                       TextWrapping="Wrap" />
            <TextBlock Classes="mm-setting-body"
                       Text="{Binding UpdateStatusMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <Button Grid.Row="0"
                  Grid.Column="1"
                  Classes="mm-settings-close"
                  Command="{Binding DismissUpdateNotificationCommand}"
                  ToolTip.Tip="{Binding UpdateNotificationDismiss}">
            <Path Data="M0,0 L10,10 M10,0 L0,10"
                  Stroke="{DynamicResource MmTextFaintBrush}"
                  StrokeThickness="1.4"
                  StrokeLineCap="Round" />
          </Button>
          <StackPanel Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Classes="mm-dialog-primary"
                    Content="{Binding DownloadUpdateLabel}"
                    Command="{Binding DownloadUpdateCommand}"
                    IsVisible="{Binding CanDownloadAvailableUpdate}" />
            <Button Classes="mm-dialog-secondary"
                    Content="{Binding DownloadedUpdateActionLabel}"
                    Command="{Binding OpenDownloadedUpdateCommand}"
                    IsVisible="{Binding CanOpenDownloadedUpdate}" />
          </StackPanel>
        </Grid>
      </Border>

      <Popup Name="AppMenuPanel"
             ZIndex="1000"
             IsOpen="{Binding IsAppOverlayOpen}"
             PlacementTarget="{Binding #AppMenuTriggerButton}"
             Placement="BottomEdgeAlignedLeft"
             VerticalOffset="8"
             Topmost="False"
             ShouldUseOverlayLayer="False">
        <!-- App overlay child views hydrated lazily in code-behind (perf F1). -->
      </Popup>

      <Popup Name="SettingsPanel"
             ZIndex="1000"
             IsOpen="{Binding IsSettingsOpen}"
             PlacementTarget="{Binding #SettingsTriggerButton}"
             Placement="BottomEdgeAlignedRight"
             VerticalOffset="8"
             Topmost="False"
             ShouldUseOverlayLayer="False">
        <!-- ReadingSettingsPanelView hydrated lazily in code-behind (perf F1) -->
      </Popup>

      <Border Classes="mm-status"
              ZIndex="300"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Bottom"
              Padding="20,0,20,14"
              IsHitTestVisible="False">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="18"
                      VerticalAlignment="Bottom"
                      IsVisible="{Binding ShowsReadingStatus}">
            <TextBlock Text="{Binding WordCountStatusLabel}"
                        FontSize="11"
                        Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding ShowsReadingStatus}" />
            <TextBlock Text="{Binding ReadTimeStatusLabel}"
                        FontSize="11"
                        Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding ShowsReadingStatus}" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="14"
                      VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text="O"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding StatusOpen}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text="E"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding EditShortcutLabel}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl"
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text=","
                           FontFamily="{DynamicResource MmDocumentMonoFontFamily}"
                           FontSize="10" />
              </Border>
              <TextBlock Text="{Binding StatusPrefs}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextFaintBrush}"
                         VerticalAlignment="Center"
                         Margin="2,0,0,0" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <Border IsVisible="{Binding IsDragHovering}"
              IsHitTestVisible="False"
              Background="{DynamicResource MmAccentSoftBrush}"
              BorderBrush="{DynamicResource MmAccentBrush}"
              BorderThickness="2"
              CornerRadius="10"
              Margin="12">
        <TextBlock Text="{Binding DragDropHint}"
                   FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                   FontSize="14"
                   Foreground="{DynamicResource MmAccentBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

      <Grid IsVisible="{Binding IsDirtyPromptOpen}"
            Background="#66000000">
        <Border Classes="mm-dialog-card"
                Width="420"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel>
            <TextBlock Classes="mm-dialog-title"
                       Text="{Binding DirtyPromptTitle}" />
            <TextBlock Classes="mm-dialog-body"
                       Text="{Binding DirtyPromptMessage}" />
            <Border Classes="mm-dialog-error-shell"
                    IsVisible="{Binding HasDirtyPromptError}">
              <TextBlock Classes="mm-dialog-error"
                         Text="{Binding DirtyPromptErrorMessage}" />
            </Border>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,18,0,0">
              <Button Classes="mm-dialog-secondary"
                      Content="{Binding DirtyPromptCancel}"
                      Command="{Binding CancelDirtyPromptCommand}" />
              <Button Classes="mm-dialog-secondary"
                      Content="{Binding DirtyPromptDiscard}"
                      Command="{Binding ConfirmDirtyDiscardCommand}" />
              <Button Classes="mm-dialog-primary"
                      Content="{Binding DirtyPromptSave}"
                      Command="{Binding ConfirmDirtySaveCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Panel>

    </Grid>
  </Border>

</Window>
