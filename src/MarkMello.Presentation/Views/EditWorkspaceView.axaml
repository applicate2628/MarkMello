<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MarkMello.Presentation.ViewModels"
             xmlns:views="using:MarkMello.Presentation.Views"
             xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
             mc:Ignorable="d"
             x:Class="MarkMello.Presentation.Views.EditWorkspaceView"
             x:DataType="vm:EditorSessionViewModel">

  <UserControl.Styles>
    <!-- Keep AvaloniaEdit's internal ScrollViewer always-visible (no auto-hide).
         Style-level targeting of the inner ScrollViewer avoids the cold-start
         regression seen with attached-property inheritance from the TextEditor
         element itself — the Style only resolves at template-apply time, not
         as a TextEditor property change. -->
    <Style Selector="avaloniaEdit|TextEditor /template/ ScrollViewer">
      <Setter Property="AllowAutoHide" Value="False" />
    </Style>
  </UserControl.Styles>

  <Grid Name="EditGrid"
        ClipToBounds="True">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"
                        MinWidth="280" />
      <ColumnDefinition Width="1" />
      <ColumnDefinition Width="*"
                        MinWidth="280" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Classes="mm-editor-pane">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Classes="mm-editor-toolbar">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="2">
              <Button Classes="mm-editor-toolbar-button"
                      Tag="Bold"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorBoldTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M4 2.5h3.5a2 2 0 0 1 0 4H4zM4 6.5h4a2 2 0 0 1 0 4H4z"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="2"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="mm-editor-toolbar-button"
                      Tag="Italic"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorItalicTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M6 2.5h4M4 11.5h4M8 2.5l-2 9"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="mm-editor-toolbar-button"
                      Tag="Code"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorCodeTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M5 4.5L2.5 7 5 9.5M9 4.5L11.5 7 9 9.5"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
              <Border Classes="mm-editor-toolbar-separator" />
              <Button Classes="mm-editor-toolbar-button"
                      Tag="Link"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorLinkTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M6 8L8 6M5.5 9.5l-1 1a2.1 2.1 0 0 1-3-3l1-1M8.5 4.5l1-1a2.1 2.1 0 0 1 3 3l-1 1"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="mm-editor-toolbar-button"
                      Tag="List"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorListTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M5 4h7M5 7h7M5 10h7M2.5 4h.01M2.5 7h.01M2.5 10h.01"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
              <Button Classes="mm-editor-toolbar-button"
                      Tag="Quote"
                      Click="OnFormatButtonClick"
                      ToolTip.Tip="{Binding EditorQuoteTooltip}">
                <Viewbox Width="14"
                         Height="14"
                         Stretch="Uniform">
                  <Canvas Width="14"
                          Height="14">
                    <Path Data="M3 4.5v4a1.5 1.5 0 0 1-1.5 1.5M7 4.5v4a1.5 1.5 0 0 1-1.5 1.5M1.5 4.5h3M5.5 4.5h3"
                          Stroke="{DynamicResource MmTextSoftBrush}"
                          StrokeThickness="1.5"
                          StrokeLineCap="Round"
                          StrokeJoin="Round"
                          Fill="Transparent" />
                  </Canvas>
                </Viewbox>
              </Button>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Classes="mm-editor-toolbar-label"
                       Text="{Binding EditorSourceLabel}" />
          </Grid>
        </Border>

        <Grid Grid.Row="1">
          <!-- SPIKE: source pane swapped from TextBox to AvaloniaEdit.TextEditor.
               Binding wired in code-behind (AvaloniaEdit has no Text DP).
               Padding lives on a wrapping Border, not on the TextEditor:
               adding non-default properties directly on the TextEditor
               (Padding, Background, ScrollViewer.AllowAutoHide, etc.)
               caused a cold-start WebView2 commit regression — the
               renderer never emitted mm-initial-visible-ready and the
               preview HWND stayed hidden. Border-wrap is the safe shape. -->
          <Border Padding="36,0,0,0"
                  Background="{DynamicResource MmElevatedBackgroundBrush}">
            <!-- Interim shape while parallel review-loop runs:
                  left=36   → text indent inside editor pane
                  top=0     → scrollbar reaches the top edge (no 28 px head-start)
                  right=0   → scrollbar at the actual right edge
                  bottom=0  → text fills bottom
                Right/top/bottom indents will need a template-level
                TextArea-margin path to keep both text inset AND
                scrollbar at outer edges; the parallel review-loop is
                evaluating that. AllowAutoHide for the scrollbar also
                still pending (broke cold-start in earlier attempt). -->
            <avaloniaEdit:TextEditor Name="EditorTextEditor"
                                      Classes="mm-editor-textarea"
                                      ShowLineNumbers="False"
                                      WordWrap="True"
                                      VerticalScrollBarVisibility="Visible"
                                      HorizontalScrollBarVisibility="Disabled" />
          </Border>

          <Border Classes="mm-editor-status-shell"
                  IsVisible="{Binding HasStatusMessage}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  Margin="18,12,18,0"
                  ZIndex="1">
            <TextBlock Classes="mm-editor-status-text"
                       Text="{Binding StatusMessage}" />
          </Border>
        </Grid>
      </Grid>
    </Border>

    <GridSplitter Grid.Column="1"
                  Name="EditorSplitter"
                  Classes="mm-editor-splitter"
                  ZIndex="2"
                  ResizeDirection="Columns"
                  ResizeBehavior="PreviousAndNext"
                  PointerPressed="OnSplitterPointerPressed"
                  PointerReleased="OnSplitterPointerReleased"
                  PointerCaptureLost="OnSplitterPointerCaptureLost"
                  DragCompleted="OnSplitterDragCompleted" />

    <ScrollViewer Name="PreviewScrollViewer"
                  Grid.Column="2"
                  MinWidth="280"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  UseLayoutRounding="True">
      <Grid UseLayoutRounding="True">
        <Border MaxWidth="{Binding DocumentColumnMaxWidth}"
                HorizontalAlignment="Center"
                UseLayoutRounding="True">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="MaxWidth"
                                Duration="0:0:0.18" />
            </Transitions>
          </Border.Transitions>
          <views:MarkdownDocumentView Name="PreviewDocumentView"
                                      Document="{Binding RenderedPreview}"
                                      DocumentPadding="72,96,72,160"
                                      ReadingPreferences="{Binding ReadingPreferences}"
                                      ImageSourceResolver="{Binding ImageSourceResolver}"
                                      UseLayoutRounding="True" />
        </Border>
      </Grid>
    </ScrollViewer>

  </Grid>
</UserControl>
