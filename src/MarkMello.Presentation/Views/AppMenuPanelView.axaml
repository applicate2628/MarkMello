<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MarkMello.Presentation.ViewModels"
             mc:Ignorable="d"
             x:Class="MarkMello.Presentation.Views.AppMenuPanelView"
             x:DataType="vm:MainWindowViewModel">
      <Border
              Classes="mm-settings-panel mm-popover-left mm-app-menu-panel"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="0"
                         Text="{Binding AppMenuHeader}" />
              <Button Grid.Column="1"
                      Classes="mm-settings-close"
                      Command="{Binding CloseOverlayCommand}"
                      ToolTip.Tip="{Binding OverlayCloseMenu}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Button Classes="mm-menu-item"
                      Command="{Binding OpenFileCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding AppMenuOpenFileLabel}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding AppMenuOpenFileHint}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="Ctrl O" />
                </Grid>
              </Button>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Button Classes="mm-menu-item"
                      Command="{Binding CloseFileCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding AppMenuCloseFileLabel}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding AppMenuCloseFileHint}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding MetaCurrent}" />
                </Grid>
              </Button>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Border Classes="mm-setting-row">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding UpdatesLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding UpdatesHint}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Classes="mm-setting-meta"
                               Text="{Binding UpdateStateBadge}" />
                  </Grid>

                  <StackPanel Spacing="4">
                    <TextBlock Classes="mm-setting-label"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding UpdateStatusTitle}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="mm-setting-body"
                               Text="{Binding UpdateStatusMessage}"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Orientation="Horizontal"
                              Spacing="8">
                    <Button Classes="mm-dialog-secondary"
                            Content="{Binding CheckForUpdatesLabel}"
                            Command="{Binding CheckForUpdatesCommand}" />
                    <Button Classes="mm-dialog-primary"
                            Content="{Binding DownloadUpdateLabel}"
                            Command="{Binding DownloadUpdateCommand}"
                            IsVisible="{Binding CanDownloadAvailableUpdate}" />
                  </StackPanel>

                  <Button Classes="mm-dialog-secondary"
                          Content="{Binding DownloadedUpdateActionLabel}"
                          Command="{Binding OpenDownloadedUpdateCommand}"
                          IsVisible="{Binding CanOpenDownloadedUpdate}" />
                </StackPanel>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Button Classes="mm-menu-item"
                      Command="{Binding OpenAppSettingsCommand}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              HorizontalAlignment="Left">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding AppMenuSettingsLabel}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding AppMenuSettingsHint}" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Classes="mm-setting-meta"
                             Text="{Binding MetaOpen}" />
                </Grid>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
</UserControl>
