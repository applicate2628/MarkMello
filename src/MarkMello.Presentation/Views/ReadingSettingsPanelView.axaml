<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MarkMello.Presentation.ViewModels"
             mc:Ignorable="d"
             x:Class="MarkMello.Presentation.Views.ReadingSettingsPanelView"
             x:DataType="vm:MainWindowViewModel">
      <Border
              Classes="mm-settings-panel mm-popover-right mm-reading-panel"
              Width="320">
        <StackPanel>
          <Border Classes="mm-settings-head-shell">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <TextBlock Classes="mm-settings-title"
                         Grid.Column="0"
                         Text="{Binding ReadingHeader}" />
              <Button Grid.Column="1"
                      Classes="mm-settings-close"
                      Command="{Binding CloseSettingsCommand}"
                      ToolTip.Tip="{Binding OverlayCloseSettings}">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{DynamicResource MmTextFaintBrush}"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="mm-settings-body-shell">
            <StackPanel Spacing="0">
              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding ReadingPaletteLabel}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding ReadingPaletteHint}" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Classes="mm-segmented"
                          HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                Spacing="1">
                      <RadioButton Classes="mm-segmented-item"
                                   GroupName="ReadingPalette"
                                   IsChecked="{Binding IsOriginalPaletteSelected}">
                        <TextBlock Text="{Binding ReadingPaletteOriginal}" />
                      </RadioButton>
                      <RadioButton Classes="mm-segmented-item"
                                   GroupName="ReadingPalette"
                                   IsChecked="{Binding IsWhitePaletteSelected}">
                        <TextBlock Text="{Binding ReadingPaletteWhite}" />
                      </RadioButton>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <Line Classes="mm-setting-divider"
                    StartPoint="0,0.5"
                    EndPoint="1,0.5" />

              <Border Classes="mm-setting-row">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <StackPanel Grid.Column="0"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Classes="mm-setting-label"
                               Text="{Binding ReadingFontLabel}" />
                    <TextBlock Classes="mm-setting-hint"
                               Text="{Binding ReadingFontHint}" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Classes="mm-segmented"
                          HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"
                                Spacing="1">
                      <RadioButton Classes="mm-segmented-item"
                                   GroupName="ReadingFont"
                                   IsChecked="{Binding IsSerifFontSelected}">
                        <TextBlock Text="{Binding ReadingFontSerif}" />
                      </RadioButton>
                      <RadioButton Classes="mm-segmented-item"
                                   GroupName="ReadingFont"
                                   IsChecked="{Binding IsSansFontSelected}">
                        <TextBlock Text="{Binding ReadingFontSans}" />
                      </RadioButton>
                      <RadioButton Classes="mm-segmented-item"
                                   GroupName="ReadingFont"
                                   IsChecked="{Binding IsMonoFontSelected}">
                        <TextBlock Text="{Binding ReadingFontMono}" />
                      </RadioButton>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingSizeLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingSizeHint}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                                  VerticalAlignment="Center">
                      <Slider Classes="mm-settings-slider"
                              Minimum="14"
                              Maximum="24"
                              TickFrequency="1"
                              IsSnapToTickEnabled="True"
                              Value="{Binding FontSizeSetting, Mode=TwoWay}" />
                      <TextBlock Classes="mm-slider-value"
                                 Text="{Binding FontSizeLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingLineHeightLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingLineHeightHint}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                                  VerticalAlignment="Center">
                      <Slider Classes="mm-settings-slider"
                              Minimum="1"
                              Maximum="3"
                              TickFrequency="0.05"
                              IsSnapToTickEnabled="True"
                              Value="{Binding LineHeightSetting, Mode=TwoWay}" />
                      <TextBlock Classes="mm-slider-value"
                                 Text="{Binding LineHeightLabel}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingWidthLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingWidthHint}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="mm-segmented"
                            HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="1">
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingWidth"
                                     IsChecked="{Binding IsNarrowWidthSelected}">
                          <TextBlock Text="{Binding ReadingWidthNarrow}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingWidth"
                                     IsChecked="{Binding IsMediumWidthSelected}">
                          <TextBlock Text="{Binding ReadingWidthMedium}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingWidth"
                                     IsChecked="{Binding IsWideWidthSelected}">
                          <TextBlock Text="{Binding ReadingWidthWide}" />
                        </RadioButton>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </StackPanel>


              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingResizerLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingResizerHint}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="mm-segmented"
                            HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="1">
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingResizer"
                                     IsChecked="{Binding IsWidthResizerOnHoverSelected}">
                          <TextBlock Text="{Binding ReadingResizerOnHover}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingResizer"
                                     IsChecked="{Binding IsWidthResizerAlwaysSelected}">
                          <TextBlock Text="{Binding ReadingResizerAlways}" />
                        </RadioButton>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </StackPanel>


              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingMinimapLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingMinimapHint}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="mm-segmented"
                            HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="1">
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingMinimap"
                                     IsChecked="{Binding IsDocumentMinimapAutoSelected}">
                          <TextBlock Text="{Binding ReadingMinimapAuto}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingMinimap"
                                     IsChecked="{Binding IsDocumentMinimapOnSelected}">
                          <TextBlock Text="{Binding ReadingMinimapOn}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingMinimap"
                                     IsChecked="{Binding IsDocumentMinimapOffSelected}">
                          <TextBlock Text="{Binding ReadingMinimapOff}" />
                        </RadioButton>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="0">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingModeSmoothLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingModeSmoothHint}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                      <Border Classes="mm-segmented"
                              HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="1">
                          <RadioButton Classes="mm-segmented-item"
                                       GroupName="ReadingSmooth"
                                       IsChecked="{Binding IsModeSwitchSmoothEnabled}">
                            <TextBlock Text="{Binding ReadingModeSmoothOn}" />
                          </RadioButton>
                          <RadioButton Classes="mm-segmented-item"
                                       GroupName="ReadingSmooth"
                                       IsChecked="{Binding IsModeSwitchSmoothDisabled}">
                            <TextBlock Text="{Binding ReadingModeSmoothOff}" />
                          </RadioButton>
                        </StackPanel>
                      </Border>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="10"
                                  VerticalAlignment="Center">
                        <Slider Classes="mm-settings-slider"
                                Width="118"
                                Minimum="0"
                                Maximum="600"
                                TickFrequency="20"
                                IsSnapToTickEnabled="True"
                                IsEnabled="{Binding IsModeSwitchSmoothEnabled}"
                                Value="{Binding ModeSwitchSmoothDurationSetting, Mode=TwoWay}" />
                        <TextBlock Classes="mm-slider-value"
                                   Text="{Binding ModeSwitchSmoothDurationLabel}" />
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <!-- Applicate fork: renderer toggle row hidden because
                   WebView is the only renderer the Applicate-side build
                   supports (the native Avalonia backend was removed in
                   the renderer-flash cleanup). The fork enforces the
                   WebView-only invariant in
                   ApplicateMainWindow.InstallApplicateRendererPolicy
                   (in-memory) and ApplicateRendererCoercingSettingsStore
                   (on-disk). To re-expose the toggle in an upstream-style
                   build, restore IsVisible to true and remove the
                   coercion in both surfaces. -->
              <StackPanel Spacing="0" IsVisible="False">
                <Line Classes="mm-setting-divider"
                      StartPoint="0,0.5"
                      EndPoint="1,0.5" />
                <Border Classes="mm-setting-row">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                      <TextBlock Classes="mm-setting-label"
                                 Text="{Binding ReadingRendererLabel}" />
                      <TextBlock Classes="mm-setting-hint"
                                 Text="{Binding ReadingRendererHint}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="mm-segmented"
                            HorizontalAlignment="Right">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="1">
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingRenderer"
                                     IsChecked="{Binding IsNativeRendererSelected}">
                          <TextBlock Text="{Binding ReadingRendererNative}" />
                        </RadioButton>
                        <RadioButton Classes="mm-segmented-item"
                                     GroupName="ReadingRenderer"
                                     IsChecked="{Binding IsWebViewRendererSelected}">
                          <TextBlock Text="{Binding ReadingRendererWebView}" />
                        </RadioButton>
                      </StackPanel>
                    </Border>
                  </Grid>
                </Border>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
</UserControl>
